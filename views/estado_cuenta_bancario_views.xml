<!-- views/estado_cuenta_bancario_views.xml -->
<odoo>

    <!-- ==================== -->
    <!-- Estado de Cuenta Bancario -->
    <!-- ==================== -->

    <!-- Tree View -->
    <record id="view_estado_cuenta_bancario_tree" model="ir.ui.view">
        <field name="name">estado.cuenta.bancario.tree</field>
        <field name="model">estado.cuenta.bancario</field>
        <field name="arch" type="xml">
            <tree>
                <field name="numero_cuenta"/>
                <field name="mes"/>
                <field name="movimiento_count"/>
                <field name="conciliados_count"/>
                <field name="pendientes_count"/>
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_estado_cuenta_bancario_form" model="ir.ui.view">
        <field name="name">estado.cuenta.bancario.form</field>
        <field name="model">estado.cuenta.bancario</field>
        <field name="arch" type="xml">
            <form string="Estado de Cuenta Bancario">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" icon="fa-check-circle"
                                name="action_auto_conciliar" type="object"
                                string="Conciliar Automáticamente"/>
                        <button class="oe_stat_button" icon="fa-refresh"
                                name="action_sync_purchase_orders" type="object"
                                string="Sincronizar OC"/>
                    </div>
                    <group>
                        <group>
                            <field name="numero_cuenta"/>
                        </group>
                        <group>
                            <field name="mes"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="conciliados_count"/>
                        </group>
                        <group>
                            <field name="pendientes_count"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Movimientos" name="movimientos">
                            <field name="movimiento_ids">
                                <tree editable="bottom" decoration-success="conciliado == True" decoration-muted="conciliado == False">
                                    <field name="conciliado" invisible="1"/>
                                    <field name="fecha"/>
                                    <field name="descripcion"/>
                                    <field name="retiro"/>
                                    <field name="deposito"/>
                                    <field name="saldo"/>
                                    <field name="observaciones"/>
                                    <field name="costos_gastos_count" string="# CI"/>
                                    <field name="purchase_order_ids" widget="many2many_tags" optional="show"/>
                                    <button name="action_open_conciliacion" type="object"
                                            string="Conciliar" icon="fa-link"
                                            class="oe_highlight"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <footer>
                    <button name="action_import_csv" type="object" string="Importar Movimientos desde CSV" class="btn-primary"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_estado_cuenta_bancario_search" model="ir.ui.view">
        <field name="name">estado.cuenta.bancario.search</field>
        <field name="model">estado.cuenta.bancario</field>
        <field name="arch" type="xml">
            <search string="Estado de Cuenta Bancario">
                <field name="numero_cuenta"/>
                <field name="mes"/>
                <group expand="0" string="Agrupar por">
                    <filter string="Número de Cuenta" name="group_cuenta" context="{'group_by': 'numero_cuenta'}"/>
                    <filter string="Mes" name="group_mes" context="{'group_by': 'mes:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_estado_cuenta_bancario" model="ir.actions.act_window">
        <field name="name">Estados de Cuenta Bancarios</field>
        <field name="res_model">estado.cuenta.bancario</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_estado_cuenta_bancario_search"/>
    </record>

    <!-- ==================== -->
    <!-- Movimiento Bancario (Form for conciliation) -->
    <!-- ==================== -->

    <record id="view_estado_cuenta_bancario_line_form" model="ir.ui.view">
        <field name="name">estado.cuenta.bancario.line.form</field>
        <field name="model">estado.cuenta.bancario.line</field>
        <field name="arch" type="xml">
            <form string="Movimiento Bancario">
                <sheet>
                    <div class="oe_title">
                        <h3>
                            <field name="conciliado" widget="boolean" invisible="1"/>
                            <span attrs="{'invisible': [('conciliado', '=', False)]}">✓ Conciliado</span>
                            <span attrs="{'invisible': [('conciliado', '=', True)]}" style="color: #dc3545;">✗ Pendiente</span>
                        </h3>
                    </div>
                    <group>
                        <group string="Datos del Movimiento">
                            <field name="estado_cuenta_id" readonly="1"/>
                            <field name="fecha"/>
                            <field name="descripcion"/>
                        </group>
                        <group string="Montos">
                            <field name="retiro"/>
                            <field name="deposito"/>
                            <field name="saldo"/>
                        </group>
                    </group>
                    <group>
                        <field name="observaciones"/>
                    </group>
                    <separator string="Órdenes de Compra"/>
                    <field name="purchase_order_ids" widget="many2many_tags"/>
                    <separator string="Líneas de Control Interno Relacionadas"/>
                    <field name="mes_estado_cuenta" invisible="1"/>
                    <field name="costos_gastos_line_ids" widget="many2many_tags"
                           context="{'default_fecha_pago': fecha}"
                           domain="[]"/>
                    <field name="costos_gastos_line_ids" mode="tree" readonly="1">
                        <tree>
                            <field name="control_interno_id"/>
                            <field name="fecha_pago"/>
                            <field name="concepto"/>
                            <field name="proveedor_text"/>
                            <field name="total"/>
                            <field name="tipo_pago"/>
                        </tree>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ==================== -->
    <!-- Conciliación Manual Wizard -->
    <!-- ==================== -->

    <record id="view_conciliacion_manual_wizard_form" model="ir.ui.view">
        <field name="name">conciliacion.manual.wizard.form</field>
        <field name="model">conciliacion.manual.wizard</field>
        <field name="arch" type="xml">
            <form string="Conciliar Movimiento">
                <sheet>
                    <div class="oe_title">
                        <h3>
                            <field name="conciliado" invisible="1"/>
                            <span attrs="{'invisible': [('conciliado', '=', False)]}">
                                <span style="color: #28a745;">✓ Conciliado</span>
                            </span>
                            <span attrs="{'invisible': [('conciliado', '=', True)]}">
                                <span style="color: #dc3545;">✗ Pendiente</span>
                            </span>
                        </h3>
                    </div>
                    <group>
                        <group string="Datos del Movimiento">
                            <field name="movimiento_id" invisible="1"/>
                            <field name="estado_cuenta_id"/>
                            <field name="fecha"/>
                            <field name="descripcion"/>
                        </group>
                        <group string="Montos">
                            <field name="retiro"/>
                            <field name="deposito"/>
                            <field name="saldo"/>
                        </group>
                    </group>
                    <separator string="Líneas de Control Interno"/>
                    <field name="filtro_mes" invisible="1"/>
                    <field name="filtro_monto" invisible="1"/>
                    <field name="costos_gastos_line_ids"
                           context="{'search_default_mes': filtro_mes,
                                     'search_default_filter_monto_conciliacion': filtro_monto and 1 or 0,
                                     'conciliacion_monto': filtro_monto}">
                        <tree>
                            <field name="control_interno_id"/>
                            <field name="fecha_pago"/>
                            <field name="concepto"/>
                            <field name="proveedor_text"/>
                            <field name="total"/>
                            <field name="tipo_pago"/>
                        </tree>
                    </field>
                </sheet>
                <footer>
                    <button name="action_confirmar" type="object"
                            string="Guardar y Cerrar" class="btn-primary"/>
                    <button string="Descartar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- ==================== -->
    <!-- Movimientos (standalone) -->
    <!-- ==================== -->

    <!-- Tree View (standalone) -->
    <record id="view_estado_cuenta_bancario_line_tree" model="ir.ui.view">
        <field name="name">estado.cuenta.bancario.line.tree</field>
        <field name="model">estado.cuenta.bancario.line</field>
        <field name="arch" type="xml">
            <tree decoration-success="conciliado == True">
                <field name="estado_cuenta_id"/>
                <field name="fecha"/>
                <field name="descripcion"/>
                <field name="retiro"/>
                <field name="deposito"/>
                <field name="saldo"/>
                <field name="observaciones"/>
                <field name="conciliado"/>
                <field name="costos_gastos_count" string="# CI"/>
                <field name="purchase_order_ids" widget="many2many_tags"/>
            </tree>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_estado_cuenta_bancario_line_search" model="ir.ui.view">
        <field name="name">estado.cuenta.bancario.line.search</field>
        <field name="model">estado.cuenta.bancario.line</field>
        <field name="arch" type="xml">
            <search string="Movimientos Bancarios">
                <field name="estado_cuenta_id"/>
                <field name="fecha"/>
                <field name="descripcion"/>
                <filter string="Conciliados" name="filter_conciliados" domain="[('conciliado', '=', True)]"/>
                <filter string="Pendientes" name="filter_pendientes" domain="[('conciliado', '=', False)]"/>
                <separator/>
                <group expand="0" string="Agrupar por">
                    <filter string="Estado de Cuenta" name="group_estado" context="{'group_by': 'estado_cuenta_id'}"/>
                    <filter string="Fecha" name="group_fecha" context="{'group_by': 'fecha:month'}"/>
                    <filter string="Conciliado" name="group_conciliado" context="{'group_by': 'conciliado'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action for standalone line view -->
    <record id="action_estado_cuenta_bancario_line" model="ir.actions.act_window">
        <field name="name">Movimientos Bancarios</field>
        <field name="res_model">estado.cuenta.bancario.line</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_estado_cuenta_bancario_line_search"/>
    </record>

    <!-- ==================== -->
    <!-- Import Wizard -->
    <!-- ==================== -->

    <record id="view_estado_cuenta_bancario_import_wizard_form" model="ir.ui.view">
        <field name="name">estado.cuenta.bancario.import.wizard.form</field>
        <field name="model">estado.cuenta.bancario.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Importar Movimientos desde CSV">
                <group>
                    <field name="estado_cuenta_id" readonly="1"/>
                    <field name="csv_file" filename="filename"/>
                    <field name="filename" invisible="1"/>
                </group>
                <footer>
                    <button name="action_import" type="object" string="Importar" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
