<odoo>

    <record id="view_estado_cuenta_pdf_import_wizard_form" model="ir.ui.view">
        <field name="name">estado.cuenta.bancario.pdf.import.wizard.form</field>
        <field name="model">estado.cuenta.bancario.pdf.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Importar Movimientos desde PDF">
                <group>
                    <field name="pdf_file" filename="filename"/>
                    <field name="filename" invisible="1"/>
                    <field name="bank_code"/>
                    <field name="cuenta_bancaria_id"
                           options="{'no_create_edit': False}"
                           help="Opcional. Si el PDF contiene varias cuentas y solo te interesa una, especifícala aquí."/>
                    <field name="auto_crear_cuenta"/>
                    <field name="estado_cuenta_id" invisible="1"/>
                    <field name="forzar_reemplazo"
                           attrs="{'invisible': [('tiene_conflictos', '=', False)]}"/>
                    <field name="estados_existentes_ids" invisible="1"/>
                    <field name="tiene_conflictos" invisible="1"/>
                </group>
                <div attrs="{'invisible': [('mensaje_aviso', '=', False)]}"
                     class="alert alert-warning" role="alert">
                    <field name="mensaje_aviso" nolabel="1" readonly="1"/>
                </div>
                <footer>
                    <button name="action_import" type="object"
                            string="Importar" class="btn-primary"
                            attrs="{'invisible': [('tiene_conflictos', '=', True)]}"/>
                    <button name="action_borrar_y_reimportar" type="object"
                            string="Borrar y Reimportar" class="btn-danger"
                            attrs="{'invisible': [('tiene_conflictos', '=', False)]}"
                            confirm="Esto borrará todos los movimientos de los estados de cuenta conflictivos. ¿Continuar?"/>
                    <button name="action_abrir_existente" type="object"
                            string="Abrir Existentes" class="btn-secondary"
                            attrs="{'invisible': [('tiene_conflictos', '=', False)]}"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_estado_cuenta_pdf_import_wizard" model="ir.actions.act_window">
        <field name="name">Importar Movimientos desde PDF</field>
        <field name="res_model">estado.cuenta.bancario.pdf.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
